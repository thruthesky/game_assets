{
  "stripWhitespaceX": true,
  "stripWhitespaceY": false,
  "rotation": false,
  "pot": false,
  "maxWidth": 4096,
  "maxHeight": 4096,
  "scale": [
    0.5
  ],
  "scaleSuffix": [
    ""
  ],
  "scaleResampling": [
    "bicubic"
  ],
  "premultiplyAlpha": false,
  "edgePadding": true,
  "bleed": true,
  "paddingX": 2,
  "paddingY": 2,
  "duplicatePadding": true,
  "filterMin": "Nearest",
  "filterMag": "Nearest",
  "format": "RGBA8888",
  "ignoreBlankImages": true,
  "useIndexes": true,
  "alias": true,
  "square": false,
  "fast": true,
  "outputFormat": "png",
  "atlasExtension": ".atlas",
  "prettyPrint": true
}